{
  "name": "proof",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/worker\" \"npm run dev --workspace=apps/dashboard\"",
    "deploy:worker": "npm run deploy --workspace=apps/worker",
    "deploy:dashboard": "npm run deploy --workspace=apps/dashboard"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  }
}
