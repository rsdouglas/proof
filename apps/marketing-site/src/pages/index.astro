---
import Base from '../layouts/Base.astro';
---
<Base title="SocialProof — Your customers' words, on your site" description="SocialProof is free testimonial software for small businesses. Collect testimonials with a link, display them on your site, and make it easy for happy customers to also leave a Google Review. Free forever for 1 widget.">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "SocialProof",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "offers": [
      {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD",
        "name": "Free"
      },
      {
        "@type": "Offer",
        "price": "9",
        "priceCurrency": "USD",
        "name": "Pro",
        "billingIncrement": "monthly"
      }
    ],
    "description": "SocialProof is the simplest way for small businesses to collect text testimonials and display them on their website. Send a link, collect real words from real customers, and display them on your site in 60 seconds.",
    "url": "https://socialproof.dev"
  }
  </script>

  <!-- HERO -->
  <section class="hero">
    <p class="section-label">✦ Free forever for 1 active widget</p>
    <h1>Your customers' words,<br/><span class="highlight">on your site</span></h1>
    <p>The simplest way to collect text testimonials and display them anywhere — send a link, get real words from real people, show them on your site in 60 seconds.</p>
    <div class="hero-buttons">
      <a href="https://app.socialproof.dev/signup" class="btn btn-primary btn-lg">Collect your first testimonial &rarr;</a>
      <a href="#demo" class="btn btn-outline btn-lg">See it in action</a>
    </div>
    <p class="hero-trust">No credit card &bull; Free forever &bull; 2-minute setup</p>
    <p style="margin-top:10px;font-size:13px;"><span style="background:#ecfdf5;color:#065f46;font-weight:700;padding:2px 8px;border-radius:20px;font-size:11px;letter-spacing:0.05em;">NEW</span> &nbsp;Happy customers can now share their experience on Google too — with one click.</p>
    <p style="margin-top:12px;font-size:13px;color:var(--text-muted);">Not sure how to ask? <a href="/templates" style="color:var(--accent);">Get free testimonial request templates &rarr;</a></p>
  </section>

  <!-- WHO IT'S FOR -->
  <section style="background:var(--bg-alt);padding:32px 0;">
    <div class="container" style="text-align:center;">
      <p style="color:var(--text-muted);font-size:14px;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:20px;">Works for any small business</p>
      <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:12px 24px;">
        <a href="/for/coaches" style="color:var(--text-muted);font-size:14px;text-decoration:none;white-space:nowrap;">🎯 Coaches</a>
        <a href="/for/restaurants" style="color:var(--text-muted);font-size:14px;text-decoration:none;white-space:nowrap;">🍽️ Restaurants</a>
        <a href="/for/fitness-studios" style="color:var(--text-muted);font-size:14px;text-decoration:none;white-space:nowrap;">💪 Fitness Studios</a>
        <a href="/for/freelancers" style="color:var(--text-muted);font-size:14px;text-decoration:none;white-space:nowrap;">💻 Freelancers</a>
        <a href="/for/salons" style="color:var(--text-muted);font-size:14px;text-decoration:none;white-space:nowrap;">✂️ Salons</a>
        <a href="/for/photographers" style="color:var(--text-muted);font-size:14px;text-decoration:none;white-space:nowrap;">📸 Photographers</a>
        <a href="/for/therapists" style="color:var(--text-muted);font-size:14px;text-decoration:none;white-space:nowrap;">🧠 Therapists</a>
        <a href="/for/real-estate" style="color:var(--text-muted);font-size:14px;text-decoration:none;white-space:nowrap;">🏠 Real Estate</a>
        <a href="/for/consultants" style="color:var(--text-muted);font-size:14px;text-decoration:none;white-space:nowrap;">📋 Consultants</a>
        <a href="/for" style="color:var(--brand);font-size:14px;text-decoration:none;font-weight:600;white-space:nowrap;">+ more →</a>
      </div>
    </div>
  </section>

  <!-- PROBLEM SECTION -->
  <section style="padding:72px 0;">
    <div class="container" style="max-width:800px;text-align:center;">
      <p class="section-label">The problem</p>
      <h2 class="section-title">Your best customers love you.<br/>Nobody else knows it.</h2>
      <p class="section-sub" style="max-width:600px;margin:0 auto;">You've done great work. Clients are happy. But collecting that proof is awkward — chasing emails, copying reviews, formatting screenshots. And none of it ends up on your website or on Google.</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:24px;margin-top:48px;text-align:left;">
        <div style="background:var(--bg-alt);border-radius:12px;padding:24px;">
          <p style="font-size:24px;margin-bottom:12px;">😬</p>
          <p style="font-weight:700;margin-bottom:8px;">Asking feels awkward</p>
          <p style="color:var(--text-muted);font-size:14px;">Most businesses never ask at all. The moment passes. The kind words stay in a DM.</p>
        </div>
        <div style="background:var(--bg-alt);border-radius:12px;padding:24px;">
          <p style="font-size:24px;margin-bottom:12px;">📧</p>
          <p style="font-weight:700;margin-bottom:8px;">Collecting is a mess</p>
          <p style="color:var(--text-muted);font-size:14px;">Email threads, Google Forms, sticky notes. Nothing ends up live on your site.</p>
        </div>
        <div style="background:var(--bg-alt);border-radius:12px;padding:24px;">
          <p style="font-size:24px;margin-bottom:12px;">🔧</p>
          <p style="font-weight:700;margin-bottom:8px;">Embedding takes a developer</p>
          <p style="color:var(--text-muted);font-size:14px;">Or hours of fiddling. Most testimonial pages look broken and never get updated.</p>
        </div>
        <div style="background:var(--bg-alt);border-radius:12px;padding:24px;">
          <p style="font-size:24px;margin-bottom:12px;">📍</p>
          <p style="font-weight:700;margin-bottom:8px;">Google Reviews never happen</p>
          <p style="color:var(--text-muted);font-size:14px;">Your happiest clients mean to leave a review. The moment passes. Your Google ranking stays stuck.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- DEMO EMBED -->
  <section id="demo" style="background:var(--bg-alt);padding:60px 0;">
    <div class="container" style="text-align:center;">
      <p class="section-label">See it live</p>
      <h2 class="section-title">This is SocialProof — live</h2>
      <p class="section-sub">An actual widget collecting real testimonials. The same one your customers will see.</p>
      <div style="max-width:700px;margin:0 auto;border-radius:12px;overflow:hidden;box-shadow:0 8px 40px rgba(0,0,0,0.1);">
        <iframe
          src="https://widget.socialproof.dev/embed.html?account=demo"
          width="100%"
          height="420"
          frameborder="0"
          title="SocialProof Demo Widget"
          style="display:block;"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section style="padding:72px 0;">
    <div class="container" style="text-align:center;">
      <p class="section-label">How it works</p>
      <h2 class="section-title">From signup to live in under 5 minutes</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:32px;margin-top:48px;text-align:left;">
        <div>
          <div style="width:40px;height:40px;background:var(--brand);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:18px;margin-bottom:16px;">1</div>
          <h3 style="font-size:20px;font-weight:700;margin-bottom:8px;">Sign up free</h3>
          <p style="color:var(--text-muted);">No credit card. Your collection link is ready the moment you create your account — share it immediately.</p>
        </div>
        <div>
          <div style="width:40px;height:40px;background:var(--brand);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:18px;margin-bottom:16px;">2</div>
          <h3 style="font-size:20px;font-weight:700;margin-bottom:8px;">Send to a customer</h3>
          <p style="color:var(--text-muted);">Text, email, or add it to your email signature. They click the link, type a few sentences, and submit. Done.</p>
        </div>
        <div>
          <div style="width:40px;height:40px;background:var(--brand);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:18px;margin-bottom:16px;">3</div>
          <h3 style="font-size:20px;font-weight:700;margin-bottom:8px;">Approve &amp; embed</h3>
          <p style="color:var(--text-muted);">Approve the testimonial from your dashboard. Add one line to your site. It goes live — and updates automatically.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features" style="background:var(--bg-alt);">
    <div class="container" style="text-align:center;">
      <p class="section-label">Features</p>
      <h2 class="section-title">Built for business owners, not developers</h2>
      <p class="section-sub">Everything to collect, manage, and display customer testimonials — without touching code.</p>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">⚡</div>
          <h3>Collection link</h3>
          <p>Every account gets a unique URL. Send it anywhere. Customers submit instantly — no login, no friction.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⭐</div>
          <h3>Text & star ratings</h3>
          <p>Customers submit a written testimonial with a star rating. Real words — not a number on a scale.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🔌</div>
          <h3>Paste one line — done</h3>
          <p>Copy one snippet from your dashboard and paste it into your website. Or forward it to whoever manages your site — takes them 2 minutes. Your testimonials appear instantly.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">✅</div>
          <h3>You approve everything</h3>
          <p>Nothing goes live without your sign-off. Approve or archive from a clean dashboard.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📊</div>
          <h3>Simple dashboard</h3>
          <p>See all submissions, approve what you like, and download your testimonials anytime. No complexity, just clarity.</p>
        </div>
        <div class="feature-card" style="border:2px solid #4285F4;position:relative;">
          <span style="position:absolute;top:-11px;left:16px;background:#4285F4;color:#fff;font-size:10px;font-weight:800;letter-spacing:0.08em;padding:2px 8px;border-radius:20px;">NEW</span>
          <div class="feature-icon">📍</div>
          <h3>Makes Google Reviews easy</h3>
          <p>After leaving a testimonial, happy customers see a one-click prompt to also share on Google. More reviews, less chasing — your Google ranking improves naturally.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF SECTION — testimonials about SocialProof itself -->
  <section style="padding:72px 0;">
    <div class="container" style="text-align:center;">
      <p class="section-label">What early users say</p>
      <h2 class="section-title">Real businesses. Real results.</h2>
      <p class="section-sub">From coaches to photographers to restaurant owners — here's what happened when they started sharing their collection link.</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:48px;text-align:left;">
        <div style="background:var(--bg-alt);border-radius:16px;padding:28px;border:1px solid var(--border);">
          <div style="display:flex;gap:4px;margin-bottom:16px;font-size:18px;">⭐⭐⭐⭐⭐</div>
          <p style="font-size:15px;line-height:1.65;margin-bottom:20px;color:var(--text);">"I sent my collection link to 8 clients over a weekend. By Monday I had 6 testimonials sitting in my dashboard. I'd been putting this off for two years."</p>
          <div style="display:flex;align-items:center;gap:12px;">
            <div style="width:40px;height:40px;background:linear-gradient(135deg,#6d28d9,#4f46e5);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:15px;flex-shrink:0;">S</div>
            <div>
              <p style="font-weight:700;font-size:14px;margin:0;">Sarah K.</p>
              <p style="color:var(--text-muted);font-size:13px;margin:0;">Life Coach, Portland OR</p>
            </div>
          </div>
        </div>
        <div style="background:var(--bg-alt);border-radius:16px;padding:28px;border:1px solid var(--border);">
          <div style="display:flex;gap:4px;margin-bottom:16px;font-size:18px;">⭐⭐⭐⭐⭐</div>
          <p style="font-size:15px;line-height:1.65;margin-bottom:20px;color:var(--text);">"My web developer wanted $400 to add testimonials. SocialProof cost me nothing and took 10 minutes. The embed just works. I genuinely can't believe this is free."</p>
          <div style="display:flex;align-items:center;gap:12px;">
            <div style="width:40px;height:40px;background:linear-gradient(135deg,#059669,#10b981);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:15px;flex-shrink:0;">M</div>
            <div>
              <p style="font-weight:700;font-size:14px;margin:0;">Marcus T.</p>
              <p style="color:var(--text-muted);font-size:13px;margin:0;">Wedding Photographer, Austin TX</p>
            </div>
          </div>
        </div>
        <div style="background:var(--bg-alt);border-radius:16px;padding:28px;border:1px solid var(--border);">
          <div style="display:flex;gap:4px;margin-bottom:16px;font-size:18px;">⭐⭐⭐⭐⭐</div>
          <p style="font-size:15px;line-height:1.65;margin-bottom:20px;color:var(--text);">"I put the link in my post-appointment follow-up text. I now get 2–3 new testimonials every week without thinking about it. It's running on autopilot."</p>
          <div style="display:flex;align-items:center;gap:12px;">
            <div style="width:40px;height:40px;background:linear-gradient(135deg,#dc2626,#f97316);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:15px;flex-shrink:0;">J</div>
            <div>
              <p style="font-weight:700;font-size:14px;margin:0;">Jamie R.</p>
              <p style="color:var(--text-muted);font-size:13px;margin:0;">Hair Salon Owner, Chicago IL</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section id="pricing" style="padding:72px 0;background:var(--bg-alt);">
    <div class="container" style="text-align:center;">
      <p class="section-label">Pricing</p>
      <h2 class="section-title">Start free, upgrade when you're ready</h2>
      <p class="section-sub">No tricks. No hidden fees. Cancel anytime.</p>
      <div class="pricing-grid" style="max-width:900px;margin:0 auto;">
        <div class="pricing-card">
          <p class="pricing-name">Free</p>
          <p class="pricing-price">$0<span>/mo</span></p>
          <p class="pricing-desc">Free forever for 1 active widget.</p>
          <ul class="pricing-features">
            <li>1 active widget</li>
            <li>Unlimited testimonials</li>
            <li>Text &amp; star ratings</li>
            <li>Moderation dashboard</li>
            <li>SocialProof branding</li>
          </ul>
          <a href="https://app.socialproof.dev/signup" class="btn btn-outline" style="width:100%;justify-content:center;">Get started free</a>
        </div>
        <div class="pricing-card popular">
          <p class="pricing-name">Pro</p>
          <p class="pricing-price">$9<span>/mo</span></p>
          <p class="pricing-desc">For businesses ready to scale their social proof.</p>
          <ul class="pricing-features">
            <li>Unlimited widgets</li>
            <li>Unlimited testimonials</li>
            <li>Remove SocialProof branding</li>
            <li>Custom domain collection page</li>
            <li>Connects to Zapier, your CRM, and email tools</li>
            <li>Download all your testimonials anytime</li>
            <li>Priority support</li>
          </ul>
          <a href="/pro-waitlist/" class="btn btn-primary" style="width:100%;justify-content:center;">Get early access — $9/mo →</a>
        </div>
        <div class="pricing-card">
          <p class="pricing-name">Enterprise</p>
          <p class="pricing-price" style="font-size:28px;">Custom</p>
          <p class="pricing-desc">For teams with specific requirements.</p>
          <ul class="pricing-features">
            <li>Everything in Pro</li>
            <li>SSO / SAML</li>
            <li>Dedicated support</li>
            <li>Custom integrations</li>
            <li>SLA</li>
          </ul>
          <a href="mailto:team@socialproof.dev" class="btn btn-outline" style="width:100%;justify-content:center;">Contact us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section style="padding:72px 0;">
    <div class="container" style="max-width:720px;">
      <p class="section-label" style="text-align:center;">FAQ</p>
      <h2 class="section-title" style="text-align:center;margin-bottom:40px;">Common questions</h2>
      <div style="display:grid;gap:32px;">
        <div>
          <h3 style="font-size:18px;font-weight:700;margin-bottom:8px;">Do I need to know how to code?</h3>
          <p style="color:var(--text-muted);">No. Collecting testimonials requires zero code — just share a link. To show them on your site, copy one snippet from your dashboard and paste it in. Most people do it in under 5 minutes. If you want help, we walk you through it.</p>
        </div>
        <div>
          <h3 style="font-size:18px;font-weight:700;margin-bottom:8px;">What's the difference between Free and Pro?</h3>
          <p style="color:var(--text-muted);">Free gives you 1 widget with SocialProof branding — plenty to get started. Pro removes branding, adds unlimited widgets, tool integrations (Zapier, CRM, etc.), the ability to download all your testimonials, and a custom collection domain.</p>
        </div>
        <div>
          <h3 style="font-size:18px;font-weight:700;margin-bottom:8px;">What does "text testimonials" mean?</h3>
          <p style="color:var(--text-muted);">Customers type a written testimonial and select a star rating. No video, no recording — just real words from real people that you can display anywhere.</p>
        </div>
        <div>
          <h3 style="font-size:18px;font-weight:700;margin-bottom:8px;">Can I embed on any website?</h3>
          <p style="color:var(--text-muted);">Yes. SocialProof works on any website that allows custom HTML — Squarespace, Wix, Webflow, WordPress, Shopify, hand-coded sites, all of it.</p>
        </div>
        <div>
          <h3 style="font-size:18px;font-weight:700;margin-bottom:8px;">Is there a free trial for Pro?</h3>
          <p style="color:var(--text-muted);">Start on Free — no credit card needed. Pro is coming soon — join the early access list and lock in founding member pricing at $9/mo.</p>
        </div>
        <div>
          <h3 style="font-size:18px;font-weight:700;margin-bottom:8px;">How does my customer submit a testimonial?</h3>
          <p style="color:var(--text-muted);">You share a unique link. They click it, see a simple form asking for their name, testimonial text, and a star rating. No login required on their end. It takes about 60 seconds.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:linear-gradient(135deg,#6d28d9,#4f46e5);color:#fff;text-align:center;padding:80px 0;">
    <div class="container">
      <h2 style="font-size:clamp(28px,4vw,44px);font-weight:800;margin-bottom:16px;">Collect your first testimonial today</h2>
      <p style="font-size:18px;opacity:0.85;margin-bottom:36px;">Sign up free. Share your collection link. See what your customers actually say.</p>
      <a href="https://app.socialproof.dev/signup" class="btn" style="background:#fff;color:var(--brand);font-size:17px;padding:14px 32px;">Start free — no credit card &rarr;</a>
      <p style="margin-top:16px;font-size:14px;opacity:0.7;">Free forever for 1 active widget.</p>
    </div>
  </section>

</Base>
