---
import Base from '../layouts/Base.astro';
---
<Base
  title="Testimonial Request Templates — Copy-Paste Scripts for Small Businesses | SocialProof"
  description="Free copy-paste templates to ask customers for testimonials: email, SMS, DM, and in-person scripts. Proven wording that gets real responses for small businesses."
>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to Ask Customers for Testimonials",
    "description": "Step-by-step scripts and templates for requesting customer testimonials via email, text, and social media.",
    "url": "https://socialproof.dev/templates",
    "step": [
      {
        "@type": "HowToStep",
        "name": "Send a text message",
        "text": "Reach out via SMS with a personal, brief message immediately after a positive experience."
      },
      {
        "@type": "HowToStep",
        "name": "Send an email",
        "text": "Follow up with a warm email that includes your SocialProof collection link."
      },
      {
        "@type": "HowToStep",
        "name": "Ask in person",
        "text": "Ask face-to-face and offer to text them the link while you're together."
      }
    ]
  }
  </script>

  <!-- HERO -->
  <section class="hero" style="padding-bottom: 32px;">
    <p class="section-label">✦ Free resource</p>
    <h1>Testimonial request<br/><span class="highlight">templates</span></h1>
    <p>Copy-paste scripts that get real responses from real customers — for email, SMS, DM, and in person. Fill in the brackets. Hit send.</p>
    <div class="hero-buttons">
      <a href="https://app.socialproof.dev/signup" class="btn btn-primary btn-lg">Get your free collection link &rarr;</a>
    </div>
    <p class="hero-trust">No credit card &bull; Free forever &bull; 2-minute setup</p>
  </section>

  <!-- HOW IT WORKS IN 2 SENTENCES -->
  <section style="background:var(--bg-alt);padding:24px 0;">
    <div class="container" style="max-width:640px;text-align:center;">
      <p style="color:var(--text-muted);font-size:15px;line-height:1.7;">
        Each template includes a placeholder for your <strong>SocialProof link</strong> — the unique URL that takes customers straight to your testimonial form.
        <a href="https://app.socialproof.dev/signup" style="color:var(--accent);">Create your free link →</a>
      </p>
    </div>
  </section>

  <!-- MAIN CONTENT -->
  <section class="container" style="max-width:760px;padding-top:48px;padding-bottom:64px;">

    <!-- ===================== -->
    <!-- TEXT / SMS TEMPLATES  -->
    <!-- ===================== -->
    <h2 style="font-size:1.5rem;margin-bottom:8px;">📱 Text message (SMS) templates</h2>
    <p style="color:var(--text-muted);margin-bottom:24px;">Texts have 98% open rates. Use these right after a great experience — within 24 hours while the memory is fresh.</p>

    <div class="template-card">
      <div class="template-label">After a service appointment</div>
      <div class="template-body">Hi [Name]! It was great seeing you today. If you have 2 minutes, I'd love it if you left a quick testimonial — it really helps other people find us. Here's the link: [YOUR SOCIALPROOF LINK] 🙏</div>
      <button class="copy-btn" onclick="copyTemplate(this)">Copy</button>
    </div>

    <div class="template-card">
      <div class="template-label">After a product delivery</div>
      <div class="template-body">Hey [Name] — hope you're loving [product]! Would you be willing to share a quick review? Takes 2 minutes and means a lot to us: [YOUR SOCIALPROOF LINK]</div>
      <button class="copy-btn" onclick="copyTemplate(this)">Copy</button>
    </div>

    <div class="template-card">
      <div class="template-label">After a class or session</div>
      <div class="template-body">Hi [Name], thanks for joining [class/session] today! If you enjoyed it, a quick testimonial would help us grow 🙌 No pressure — but here's the link if you'd like: [YOUR SOCIALPROOF LINK]</div>
      <button class="copy-btn" onclick="copyTemplate(this)">Copy</button>
    </div>

    <div class="template-card">
      <div class="template-label">Short and direct (works for any business)</div>
      <div class="template-body">Hi [Name] — quick favor: would you write a 2-sentence testimonial for [Business Name]? Here's the link: [YOUR SOCIALPROOF LINK] — only takes a minute. Thank you!</div>
      <button class="copy-btn" onclick="copyTemplate(this)">Copy</button>
    </div>

    <!-- ===================== -->
    <!-- EMAIL TEMPLATES       -->
    <!-- ===================== -->
    <h2 style="font-size:1.5rem;margin-bottom:8px;margin-top:56px;">📧 Email templates</h2>
    <p style="color:var(--text-muted);margin-bottom:24px;">Email works best for customers you've had a relationship with. Keep it personal, not corporate. Short emails get more responses than long ones.</p>

    <div class="template-card">
      <div class="template-label">Simple request (best overall open rate)</div>
      <div class="template-body"><strong>Subject: Quick favor?</strong>

Hi [Name],

I hope things are going well! I wanted to reach out because we've really loved working with you.

Would you be willing to share a quick testimonial? It only takes 2–3 minutes and makes a huge difference for a small business like ours.

Here's the link: [YOUR SOCIALPROOF LINK]

Thank you so much — it means a lot.

[Your name]
[Business Name]</div>
      <button class="copy-btn" onclick="copyTemplate(this)">Copy</button>
    </div>

    <div class="template-card">
      <div class="template-label">After a big win / project completion</div>
      <div class="template-body"><strong>Subject: Loved working on [project] with you</strong>

Hi [Name],

It was such a pleasure working on [project/result] with you. I'm really proud of what we accomplished together.

If you'd be open to sharing your experience in a quick testimonial, I'd be incredibly grateful. It helps other businesses like yours find us — and honestly, hearing from happy clients like you is what keeps me going.

[YOUR SOCIALPROOF LINK]

No pressure at all, but if you have 2 minutes — it means the world.

Thank you,
[Your name]</div>
      <button class="copy-btn" onclick="copyTemplate(this)">Copy</button>
    </div>

    <div class="template-card">
      <div class="template-label">Follow-up (if they didn't respond to your first ask)</div>
      <div class="template-body"><strong>Subject: Still hoping to hear from you 😊</strong>

Hi [Name],

I sent you a note a couple weeks ago asking for a testimonial — just wanted to follow up one more time in case it got buried.

If you have 2 minutes, I'd love your honest words: [YOUR SOCIALPROOF LINK]

And if now isn't a good time, no worries at all!

[Your name]</div>
      <button class="copy-btn" onclick="copyTemplate(this)">Copy</button>
    </div>

    <!-- ===================== -->
    <!-- DM / SOCIAL TEMPLATES -->
    <!-- ===================== -->
    <h2 style="font-size:1.5rem;margin-bottom:8px;margin-top:56px;">💬 DM templates (Instagram, Facebook, LinkedIn)</h2>
    <p style="color:var(--text-muted);margin-bottom:24px;">Social DMs feel personal and casual — which is exactly the right tone for asking a favor. Keep it short. One sentence, one link.</p>

    <div class="template-card">
      <div class="template-label">Instagram / Facebook DM</div>
      <div class="template-body">Hey [Name]! So glad you loved [product/service] 🙌 Would you mind leaving a quick testimonial? Here's the link — takes 2 minutes: [YOUR SOCIALPROOF LINK] Thank you!!</div>
      <button class="copy-btn" onclick="copyTemplate(this)">Copy</button>
    </div>

    <div class="template-card">
      <div class="template-label">LinkedIn DM (professional services)</div>
      <div class="template-body">Hi [Name], it was great working together on [project]. I'm building out my client testimonials — would you be willing to share a few words about your experience? Here's a quick link: [YOUR SOCIALPROOF LINK] Happy to return the favor anytime.</div>
      <button class="copy-btn" onclick="copyTemplate(this)">Copy</button>
    </div>

    <!-- ===================== -->
    <!-- IN-PERSON SCRIPTS     -->
    <!-- ===================== -->
    <h2 style="font-size:1.5rem;margin-bottom:8px;margin-top:56px;">🗣️ In-person scripts</h2>
    <p style="color:var(--text-muted);margin-bottom:24px;">The best time to ask for a testimonial is right when a customer expresses satisfaction — face to face. Have your link ready.</p>

    <div class="template-card">
      <div class="template-label">When a customer says "I love this!"</div>
      <div class="template-body">"I'm so glad! Would you be willing to put that into a quick written testimonial? I have a link — it takes literally 2 minutes. Can I text it to you right now?"</div>
      <button class="copy-btn" onclick="copyTemplate(this)">Copy</button>
    </div>

    <div class="template-card">
      <div class="template-label">At checkout / end of session</div>
      <div class="template-body">"Thanks so much — it was great working with you. If you're happy with everything, a quick testimonial would mean a lot to me. I'll text you the link so you have it whenever."</div>
      <button class="copy-btn" onclick="copyTemplate(this)">Copy</button>
    </div>

    <!-- ===================== -->
    <!-- TIPS                  -->
    <!-- ===================== -->
    <div style="background:var(--bg-alt);border-radius:12px;padding:28px 32px;margin-top:56px;">
      <h2 style="font-size:1.25rem;margin-bottom:16px;">💡 What makes a testimonial request actually work</h2>
      <ul style="color:var(--text-muted);line-height:2;padding-left:20px;">
        <li><strong>Ask soon</strong> — the best time is within 24 hours of a great experience, when emotions are still high.</li>
        <li><strong>Be specific</strong> — "write a quick testimonial about [specific thing]" is easier to respond to than a vague ask.</li>
        <li><strong>Make it one click</strong> — include your SocialProof link directly. Don't make them navigate anywhere.</li>
        <li><strong>Keep it personal</strong> — first name, reference something specific. A template is a starting point, not a robot message.</li>
        <li><strong>Follow up once</strong> — people get busy. One friendly follow-up (with a two-week gap) is totally appropriate.</li>
        <li><strong>Make it easy to say "any length is fine"</strong> — 2–3 sentences is perfect. Remove the pressure of writing an essay.</li>
      </ul>
    </div>

    <!-- CTA -->
    <div style="text-align:center;margin-top:56px;padding:40px;background:linear-gradient(135deg,#f5f3ff,#ede9fe);border-radius:16px;">
      <h2 style="font-size:1.5rem;margin-bottom:12px;">Ready to collect your first testimonial?</h2>
      <p style="color:var(--text-muted);margin-bottom:24px;max-width:440px;margin-left:auto;margin-right:auto;">Create your free collection link in 2 minutes. Paste it into any of the templates above and start sending.</p>
      <a href="https://app.socialproof.dev/signup" class="btn btn-primary btn-lg">Get your free link &rarr;</a>
      <p style="color:var(--text-muted);font-size:13px;margin-top:12px;">No credit card &bull; Free forever for 1 widget</p>
    </div>

  </section>

  <!-- COPY FUNCTIONALITY -->
  <script is:inline>
    function copyTemplate(btn) {
      const card = btn.closest('.template-card');
      const body = card.querySelector('.template-body');
      navigator.clipboard.writeText(body.innerText).then(function() {
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(function() {
          btn.textContent = 'Copy';
          btn.classList.remove('copied');
        }, 2000);
      });
    }
  </script>

  <!-- STYLES -->
  <style>
    .template-card {
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 20px 24px 16px;
      margin-bottom: 16px;
      position: relative;
      background: #fff;
    }
    .template-label {
      font-size: 12px;
      font-weight: 600;
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 10px;
    }
    .template-body {
      font-size: 14px;
      line-height: 1.75;
      color: var(--text);
      white-space: pre-line;
      font-family: inherit;
      background: var(--bg-alt);
      border-radius: 6px;
      padding: 14px 16px;
      margin-bottom: 12px;
    }
    .copy-btn {
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 6px;
      padding: 6px 16px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s;
    }
    .copy-btn:hover { background: #5b21b6; }
    .copy-btn.copied { background: #059669; }
  </style>

</Base>
