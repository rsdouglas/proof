---
import Base from '../../layouts/Base.astro';
---
<Base title="SocialProof vs Stamped.io — Testimonials Without the Shopify Lock-In">
  <section style="background:var(--bg-alt); padding:80px 0 60px;">
    <div class="container" style="max-width:860px; margin:0 auto; padding:0 24px;">
      <p style="color:var(--primary); font-weight:600; margin-bottom:12px; font-size:14px; text-transform:uppercase; letter-spacing:.08em;">SocialProof vs Stamped.io</p>
      <h1 style="font-size:clamp(2rem,4vw,3rem); font-weight:800; line-height:1.15; margin-bottom:20px;">
        Collecting testimonials shouldn't require a Shopify store.
      </h1>
      <p style="font-size:1.2rem; color:var(--text-muted); max-width:600px; line-height:1.6;">
        Stamped.io is built for Shopify merchants. SocialProof works for any small business — whether you sell online, run a service, or take bookings offline.
      </p>
      <div style="margin-top:32px; display:flex; gap:16px; flex-wrap:wrap;">
        <a href="https://socialproof.dev/signup" class="btn-primary">Try SocialProof free</a>
        <a href="#comparison" style="display:inline-flex; align-items:center; gap:6px; color:var(--text-muted); font-weight:500; text-decoration:none; padding:12px 0;">See the comparison ↓</a>
      </div>
    </div>
  </section>

  <section id="comparison" style="padding:64px 0;">
    <div class="container" style="max-width:860px; margin:0 auto; padding:0 24px;">
      <h2 style="font-size:1.75rem; font-weight:700; text-align:center; margin-bottom:48px;">How they compare</h2>
      <div style="overflow-x:auto;">
        <table style="width:100%; border-collapse:collapse; font-size:0.95rem;">
          <thead>
            <tr style="border-bottom:2px solid var(--border);">
              <th style="text-align:left; padding:12px 16px; font-weight:700;">Feature</th>
              <th style="text-align:center; padding:12px 16px; font-weight:700; color:var(--primary);">SocialProof</th>
              <th style="text-align:center; padding:12px 16px; font-weight:700; color:var(--text-muted);">Stamped.io</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom:1px solid var(--border);">
              <td style="padding:12px 16px;">Works without Shopify</td>
              <td style="text-align:center; padding:12px 16px;">✅ Any website</td>
              <td style="text-align:center; padding:12px 16px; color:var(--text-muted);">⚠️ Shopify-first</td>
            </tr>
            <tr style="border-bottom:1px solid var(--border); background:var(--bg-alt);">
              <td style="padding:12px 16px;">Free plan</td>
              <td style="text-align:center; padding:12px 16px;">✅ Free forever (1 widget)</td>
              <td style="text-align:center; padding:12px 16px; color:var(--text-muted);">❌ Paid only</td>
            </tr>
            <tr style="border-bottom:1px solid var(--border);">
              <td style="padding:12px 16px;">Collection link (no form builder)</td>
              <td style="text-align:center; padding:12px 16px;">✅ Instant share link</td>
              <td style="text-align:center; padding:12px 16px; color:var(--text-muted);">❌ Automated email flows</td>
            </tr>
            <tr style="border-bottom:1px solid var(--border); background:var(--bg-alt);">
              <td style="padding:12px 16px;">Embed on any site</td>
              <td style="text-align:center; padding:12px 16px;">✅ One script tag</td>
              <td style="text-align:center; padding:12px 16px; color:var(--text-muted);">⚠️ Shopify widget only</td>
            </tr>
            <tr style="border-bottom:1px solid var(--border);">
              <td style="padding:12px 16px;">Price (entry)</td>
              <td style="text-align:center; padding:12px 16px;">$0 → $9/mo</td>
              <td style="text-align:center; padding:12px 16px; color:var(--text-muted);">$19+/mo</td>
            </tr>
            <tr style="background:var(--bg-alt);">
              <td style="padding:12px 16px;">Setup time</td>
              <td style="text-align:center; padding:12px 16px;">~5 minutes</td>
              <td style="text-align:center; padding:12px 16px; color:var(--text-muted);">30–60 minutes</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section style="background:var(--bg-alt); padding:64px 0;">
    <div class="container" style="max-width:860px; margin:0 auto; padding:0 24px;">
      <h2 style="font-size:1.75rem; font-weight:700; margin-bottom:32px;">When Stamped.io makes sense — and when it doesn't</h2>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:32px; margin-bottom:48px;">
        <div>
          <h3 style="font-size:1.1rem; font-weight:700; margin-bottom:12px;">Choose Stamped.io if…</h3>
          <ul style="color:var(--text-muted); line-height:1.8; padding-left:1.2em;">
            <li>You run a mid-size Shopify store with automated order review requests</li>
            <li>You need photo/video reviews tied to product SKUs</li>
            <li>You have a dev team to handle setup and integrations</li>
          </ul>
        </div>
        <div>
          <h3 style="font-size:1.1rem; font-weight:700; margin-bottom:12px;">Choose SocialProof if…</h3>
          <ul style="line-height:1.8; padding-left:1.2em;">
            <li>You run a service business: coaching, fitness, consulting, salons</li>
            <li>You don't use Shopify (or want platform independence)</li>
            <li>You want to collect testimonials today, not after a long setup</li>
            <li>You need a free plan while you're getting started</li>
          </ul>
        </div>
      </div>
      <div style="background:#fff; border:1px solid var(--border); border-radius:12px; padding:32px;">
        <p style="font-size:1.1rem; line-height:1.7; color:var(--text-muted); margin:0;">
          <strong style="color:var(--text);">Stamped.io is great product-review software for Shopify.</strong> But most small businesses aren't Shopify merchants — they're coaches, consultants, trainers, and service providers who just need a simple way to collect and display what their customers say. SocialProof is built for them.
        </p>
      </div>
    </div>
  </section>

  <section style="padding:64px 0;">
    <div class="container" style="max-width:860px; margin:0 auto; padding:0 24px; text-align:center;">
      <h2 style="font-size:2rem; font-weight:800; margin-bottom:16px;">Ready to try SocialProof?</h2>
      <p style="color:var(--text-muted); font-size:1.1rem; margin-bottom:32px;">Free forever for 1 active widget. No Shopify required.</p>
      <a href="https://socialproof.dev/signup" class="btn-primary" style="font-size:1.1rem; padding:16px 40px;">Collect your first testimonial →</a>
    </div>
  </section>
</Base>
