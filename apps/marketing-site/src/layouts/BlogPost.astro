---
import Base from './Base.astro';

export interface Props {
  title: string;
  description?: string;
  publishedAt: string;
  author?: string;
  ogImage?: string;
  slug?: string;
}

const { title, description, publishedAt, author = 'SocialProof Team', ogImage, slug } = Astro.props;
const canonical = slug ? `https://socialproof.dev/blog/${slug}` : undefined;

const dateFormatted = new Date(publishedAt).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---
<Base {title} {description} {ogImage} {canonical}>
  <main class="blog-post-page">
    <div class="container">
      <div class="blog-post-header">
        <a href="/blog" class="blog-back">&larr; All posts</a>
        <h1>{title}</h1>
        {description && <p class="blog-description">{description}</p>}
        <div class="blog-meta">
          <span>{author}</span>
          <span>&middot;</span>
          <time datetime={publishedAt}>{dateFormatted}</time>
        </div>
      </div>
      <article class="blog-post-body">
        <slot />
      </article>
    </div>
  </main>
</Base>
