---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noIndex?: boolean;
}

const {
  title,
  description = 'Turn happy customers into your best marketing. Collect testimonials in 60 seconds — free forever.',
  ogImage = '/og-default.png',
  canonical,
  noIndex = false,
} = Astro.props;

const canonicalUrl = canonical ?? Astro.url.href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noIndex && <meta name="robots" content="noindex" />}
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="stylesheet" href="/style.css" />
  <script is:inline>
    // Announcement banner
    if (localStorage.getItem('ann-banner-dismissed') === '1') {
      document.addEventListener('DOMContentLoaded', function() {
        var b = document.getElementById('ann-banner');
        if (b) b.style.display = 'none';
      });
    }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "SocialProof",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "Collect, approve, and embed customer testimonials on any website. Free to start.",
    "url": "https://socialproof.dev",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "reviewCount": "4"
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "SocialProof",
    "url": "https://socialproof.dev"
  }
  </script>
</head>
<body>
  <!-- ANNOUNCEMENT BANNER -->
  <div id="ann-banner" style="background:linear-gradient(90deg,#6d28d9,#4f46e5);color:#fff;text-align:center;padding:10px 48px 10px 16px;font-size:14px;font-weight:500;position:relative;letter-spacing:0.01em;">
    ✦ Built in public by AI &mdash; <a href="/blog/built-in-public-by-ai" style="color:#e9d5ff;text-decoration:underline;text-underline-offset:2px;">Read the story &rarr;</a>
    <button onclick="document.getElementById('ann-banner').style.display='none';localStorage.setItem('ann-banner-dismissed','1');" aria-label="Dismiss" style="position:absolute;right:14px;top:50%;transform:translateY(-50%);background:none;border:none;color:#fff;font-size:20px;cursor:pointer;line-height:1;padding:0 4px;">&times;</button>
  </div>

  <!-- NAV -->
  <nav>
    <a class="nav-logo" href="/"><img src="/logo.png" alt="SocialProof logo" width="28" height="28" /> <span>SocialProof</span></a>
    <div class="nav-links">
      <a href="/#demo">Demo</a>
      <a href="/#pricing">Pricing</a>
      <a href="/blog">Blog</a>
      <a href="/faq">FAQ</a>
      <a href="https://app.socialproof.dev">Log in</a>
      <a class="btn btn-primary" href="https://app.socialproof.dev/signup">Try free</a>
    </div>
  </nav>

  <slot />

  <!-- FOOTER -->
  <footer>
    <div class="footer-inner">
      <div class="footer-brand">
        <a href="/"><img src="/logo.png" alt="SocialProof" width="24" height="24" /> SocialProof</a>
        <p>Turn happy customers into your best marketing.</p>
      </div>
      <div class="footer-links">
        <div>
          <strong>Product</strong>
          <a href="/#features">Features</a>
          <a href="/#pricing">Pricing</a>
          <a href="/faq">FAQ</a>
          <a href="https://app.socialproof.dev/signup">Sign up free</a>
        </div>
        <div>
          <strong>Blog</strong>
          <a href="/blog">All posts</a>
        </div>
        <div>
          <strong>Legal</strong>
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} SocialProof. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>
